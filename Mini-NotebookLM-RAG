        "def read_pdf(bytes_blob: bytes) -> str:\n",
        "    reader = PdfReader(io.BytesIO(bytes_blob))\n",
        "    texts = []\n",
        "    for page in reader.pages:\n",
        "        try:\n",
        "            texts.append(page.extract_text() or \"\")\n",
        "        except:\n",
        "            texts.append(\"\")\n",
        "    return \"\\n\".join(texts)"
      ]
