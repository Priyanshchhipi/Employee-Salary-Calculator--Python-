        "with gr.Blocks(title=\"Mini NotebookLM (Local RAG)\") as demo:\n",
        "    gr.Markdown(\"# 📚 Mini NotebookLM (Local RAG) – Colab\\nUpload ➜ Summaries & FAQs ➜ Ask Questions, grounded in your docs.\")\n",
