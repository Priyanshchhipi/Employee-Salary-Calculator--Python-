        "def load_text_by_ext(fname: str, blob: bytes) -> str:\n",
        "    ext = os.path.splitext(fname)[1].lower()\n",
        "    if ext == '.txt':\n",
        "        return read_txt(blob)\n",
        "    elif ext == '.pdf':\n",
        "        return read_pdf(blob)\n",
        "    elif ext == '.docx':\n",
        "        return read_docx(blob)\n",
        "    else:\n",
        "        raise ValueError(f\"Unsupported extension: {ext}\")"
      ]
