        "    fname = TITLE_TO_NAME[title_scope]\n",
        "    faqs = doc_faqs.get(fname, [])\n",
        "    return \"\\n\".join([f\"Q{i+1}: {q}\\nA{i+1}: {a}\" for i,(q,a) in enumerate(faqs)]) or \"No FAQs.\"       # If the joined string is empty (which happens when faqs is empty), Python treats it as False. Then it returns \"No FAQs.\" instead.\n",
