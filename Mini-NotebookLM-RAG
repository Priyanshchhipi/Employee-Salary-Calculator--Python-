        "def get_faqs(title_scope):\n",
        "    if title_scope == \"All\":\n",
        "        out = []\n",
        "        for d in docs_text:\n",
        "            fname = d[\"name\"]\n",
        "            friendly = name_to_title[fname]\n",
        "            out.append(\"### \" + friendly + \"\\n\" + \"\\n\".join([f\"Q{i+1}: {q}\\nA{i+1}: {a}\" for i,(q,a) in enumerate(doc_faqs[fname])]))\n",
